# claude-usage-digest 設定ファイル
# custom/config.env にコピーして編集する（custom/ は .gitignore 対象）

# AWS プロファイル名。未設定なら起動時に質問する（例: your-profile）
AWS_PROFILE=

# 対象の sanitized LogGroup（CFn の ProjectName に合わせる）
LOG_GROUP=/demo-team/claude-otel-sanitized

# ダイジェストモード で「投稿して」と言われたときの Slack 投稿先。未設定なら投稿時に確認（例: #team-channel）
SLACK_CHANNEL=
